<div class="funding-section">
  {% if site.data.funding.affiliations %}
  <h4>Affiliations</h4>
  <ul class="list-inline">
    {% for item in site.data.funding.affiliations %}
    <li class="list-inline-item me-3 mb-2">
      <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer">{{ item.full_name }}</a> ({{ item.role }})
    </li>
    {% endfor %}
  </ul>
  {% endif %}

  {% if site.data.funding.funders %}
  <h4>Research funding</h4>
  <ul class="list-inline">
    {% for item in site.data.funding.funders %}
    <li class="list-inline-item me-3 mb-2">
      <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer">{{ item.name }}</a>
    </li>
    {% endfor %}
  </ul>
  {% endif %}

  {% if site.data.funding.industry %}
  <h4>Industry collaborations</h4>
  <ul class="list-inline">
    {% for item in site.data.funding.industry %}
    <li class="list-inline-item me-3 mb-2">
      <a href="{{ item.url }}" target="_blank" rel="noopener noreferrer">{{ item.name }}</a>
    </li>
    {% endfor %}
  </ul>
  {% endif %}
</div>
